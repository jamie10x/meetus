# Copy to .env and fill in. Never commit .env.

# --- Backend ---
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://meetus:meetus@localhost:5432/meetus?sslmode=disable
REDIS_ADDR=localhost:6379

# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me
# Ticket QR signing secret (generate: openssl rand -hex 32)
TICKET_SECRET=change-me

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Meetus.uz's own Telegram channel — every published event, from every
# organizer, auto-posts here (separate from organizers' own connected
# channels). Leave empty to disable. See deploy/README.md for how to get
# the chat ID. TELEGRAM_OFFICIAL_CHANNEL_LANGUAGE defaults to "uz".
TELEGRAM_OFFICIAL_CHANNEL_ID=
TELEGRAM_OFFICIAL_CHANNEL_LANGUAGE=uz

# Local uploads directory
UPLOAD_DIR=./uploads
# Public base URL of the API (used in image URLs)
API_BASE_URL=http://localhost:8080
# Public base URL of the web app (used in bot links)
WEB_BASE_URL=http://localhost:3000

# --- Frontend (frontend/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
