{$SITE_HOST} {
	encode gzip

	# API and uploaded images go to the Go backend.
	handle /api/* {
		reverse_proxy api:8080
	}
	handle /uploads/* {
		reverse_proxy api:8080
	}
	handle /healthz {
		reverse_proxy api:8080
	}

	# Everything else is the Next.js app.
	handle {
		reverse_proxy frontend:3000
	}
}
